# ========== MongoDB 配置 ==========
MONGO_USER=autolib
MONGO_PASS=请修改为强密码

# ========== Flask API 端口 ==========
API_PORT=5003

# ========== Session 密钥（必须修改，用 openssl rand -hex 32 生成） ==========
SECRET_KEY=change-me-to-a-random-string

# ========== 运行环境（production 时启用 SESSION_COOKIE_SECURE） ==========
FLASK_ENV=production

# ========== 管理后台 2FA ==========
ADMIN_TOTP_SECRET=7ILEQSPRPYUQ34GI3JSZD2APNPPCOGIG

# ========== 凭据加密密钥（64位hex，用 openssl rand -hex 32 生成） ==========
ENCRYPTION_KEY=

# ========== 定时预约时间（每天几点几分执行预约） ==========
SCHEDULE_HOUR=7
SCHEDULE_MINUTE=00

# ========== 邮件通知（可选，不配置则邮件通知不可用） ==========
# QQ邮箱：开启 SMTP 服务后获取授权码
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
