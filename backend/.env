# ========== MongoDB 配置 ==========
MONGO_USER=
MONGO_PASS=
MONGO_PORT=27017
DB_IP=localhost:27017

# ========== Flask API 端口 ==========
API_PORT=5003

# ========== Session 密钥（随便改成一串随机字符） ==========
SECRET_KEY=change-me-to-a-random-string-abc123

# ========== 管理后台 2FA ==========
ADMIN_USER=admin
ADMIN_PASS=your-admin-password
# TOTP 密钥（首次部署时运行下面命令生成）：
# docker compose exec flask-api python -c "import pyotp; print(pyotp.random_base32())"
# 把生成的字符串填到这里，然后访问 /admin 页面扫码绑定验证器
ADMIN_TOTP_SECRET=

# ========== 定时预约时间（每天几点几分执行预约） ==========
SCHEDULE_HOUR=19
SCHEDULE_MINUTE=55

# ========== 邮件通知（可选，不配置则邮件通知不可用） ==========
# QQ邮箱：开启 SMTP 服务后获取授权码
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
